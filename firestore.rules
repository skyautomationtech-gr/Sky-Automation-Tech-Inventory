rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserDoc() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function myRole() {
      let user = getUserDoc();
      return user != null ? user.role : null;
    }

    function getRole(uid) {
      let path = /databases/$(database)/documents/users/$(uid);
      return exists(path) ? get(path).data.role : null;
    }

    function isSuperAdmin() {
      return isSignedIn() && myRole() == 'superadmin';
    }

    function isAdmin() {
      return isSignedIn() && myRole() == 'admin';
    }

    function isStaff() {
      return isSignedIn() && myRole() == 'staff';
    }

    function isActive() {
      let user = getUserDoc();
      return user != null && user.active == true;
    }

    function hasPermission(action) {
      let userDoc = getUserDoc();
      let permsPath = /databases/$(database)/documents/settings/rolePermissions;
      let perms = exists(permsPath) ? get(permsPath).data : null;
      let override = userDoc != null ? userDoc.get(['permissionOverrides', action], 'NONE') : 'NONE';
      
      return userDoc != null && perms != null && (
        userDoc.role == 'superadmin' || 
        override == true || 
        (override == 'NONE' && (
          (userDoc.role == 'admin' && perms.admin.get(action, false) == true) ||
          (userDoc.role == 'staff' && perms.staff.get(action, false) == true)
        ))
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid == userId 
        || isSuperAdmin() 
        || (isAdmin() && request.resource.data.role == 'staff')
      );
      allow update: if isSuperAdmin()
                    || (isSignedIn() && (
                      // Protect key administrative / privilege fields from self-modification or non-superadmin updates
                      request.resource.data.get('status', resource.data.get('status', 'pending_approval')) == resource.data.get('status', 'pending_approval') &&
                      request.resource.data.get('active', resource.data.get('active', false)) == resource.data.get('active', false) &&
                      request.resource.data.get('role', resource.data.get('role', 'staff')) == resource.data.get('role', 'staff') &&
                      request.resource.data.get('subBrandAccess', resource.data.get('subBrandAccess', [])) == resource.data.get('subBrandAccess', []) &&
                      
                      // Allow updates to other fields for self or by an Admin for non-superadmin users
                      (request.auth.uid == userId || (isAdmin() && resource.data.role != 'superadmin'))
                    ));
      allow delete: if isSuperAdmin() && resource.data.role != 'superadmin';

      match /private/employment {
        allow read, write: if isSuperAdmin();
      }
    }

    match /settings/rolePermissions {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update: if isSuperAdmin() || hasPermission('manageCategories');
      allow delete: if isSuperAdmin() || (hasPermission('manageCategories') && isAdmin());
    }

    match /productColors/{colorId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin() || hasPermission('manageCategories');
    }

    match /productModels/{modelId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin() || hasPermission('manageCategories');
    }

    match /brands/{brandId} {
      allow read: if isSignedIn();
      allow create, update: if isSuperAdmin() || hasPermission('manageCategories');
      allow delete: if isSuperAdmin() || (hasPermission('manageCategories') && isAdmin());
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isActive() && (isSuperAdmin() || hasPermission('addProduct'));
      allow update: if isActive() && (
        isSuperAdmin() || (
          hasPermission('editProduct') && (
            (request.resource.data.get('deletionStatus', null) == resource.data.get('deletionStatus', null)) ||
            (request.resource.data.get('deletionStatus', null) == 'pending_approval' && isAdmin())
          )
        )
      );
      allow delete: if isSuperAdmin();
    }

    match /stockLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isActive() && (isSuperAdmin() || hasPermission('stockIn') || hasPermission('stockOut') || hasPermission('stockAdjustment'));
      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    match /attendance/{sessionId} {
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isSuperAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create, update: if isActive() && (isSuperAdmin() || hasPermission('manageOrders'));
      allow delete: if isSuperAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow create: if isActive() && (isSuperAdmin() || hasPermission('manageOrders'));
      allow update: if isActive() && (
                      (isSuperAdmin() || hasPermission('manageOrders')) ||
                      ((isSuperAdmin() || hasPermission('voidInvoice')) && 
                       request.resource.data.get('voided', false) == true && 
                       resource.data.voided == false &&
                       request.resource.data.invoiceNumber == resource.data.invoiceNumber &&
                       request.resource.data.totalAmount == resource.data.totalAmount &&
                       request.resource.data.orderId == resource.data.orderId)
                    );
      allow delete: if isSuperAdmin();
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isActive() && (isSuperAdmin() || hasPermission('manageOrders'));
    }

    match /suppliers/{supplierId} {
      allow read: if isSignedIn();
      allow write: if isActive() && (isSuperAdmin() || hasPermission('manageCategories'));
    }

    match /expenses/{expenseId} {
      allow read, write: if isActive() && isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
